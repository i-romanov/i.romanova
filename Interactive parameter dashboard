<h2 class="sr-only">Interactive parameter dashboard for Primate Open Loop model — adjust scaling factors and copy MATLAB code.</h2>

<style>
body{margin:0}
.section{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:1rem 1.25rem;margin-bottom:12px}
.section-title{font-size:13px;font-weight:500;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:.05em;margin:0 0 12px}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:8px}
.row{display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:0.5px solid var(--color-border-tertiary)}
.row:last-child{border-bottom:none}
.row label{font-size:12px;color:var(--color-text-secondary);min-width:230px;flex-shrink:0;font-family:var(--font-mono)}
.row input[type=range]{flex:1;min-width:60px}
.row .val{font-size:12px;font-weight:500;min-width:52px;text-align:right;color:var(--color-text-primary)}
.metrics-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.metric{background:var(--color-background-secondary);border-radius:var(--border-radius-md);padding:.75rem 1rem}
.metric .mlabel{font-size:11px;color:var(--color-text-secondary);margin:0 0 4px}
.metric .mval{font-size:17px;font-weight:500;color:var(--color-text-primary);margin:0}
.metric .mtarget{font-size:10px;color:var(--color-text-tertiary);margin:2px 0 0}
.badge{display:inline-block;font-size:10px;padding:2px 7px;border-radius:var(--border-radius-md);margin-left:6px}
.badge.good{background:var(--color-background-success);color:var(--color-text-success)}
.badge.warn{background:var(--color-background-warning);color:var(--color-text-warning)}
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border:0.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);background:transparent;cursor:pointer;font-size:13px;color:var(--color-text-primary)}
.btn:hover{background:var(--color-background-secondary)}
.btn.primary{background:var(--color-background-info);border-color:var(--color-border-info);color:var(--color-text-info)}
.code-box{background:var(--color-background-secondary);border-radius:var(--border-radius-md);font-family:var(--font-mono);font-size:11px;padding:1rem;white-space:pre;overflow-x:auto;max-height:280px;overflow-y:auto;color:var(--color-text-primary)}
.fitness-bar-wrap{background:var(--color-background-secondary);border-radius:var(--border-radius-md);height:8px;margin-top:8px;overflow:hidden}
.fitness-bar{height:8px;background:#1D9E75;border-radius:var(--border-radius-md);transition:width .3s}
</style>

<div style="padding:0.25rem 0 0.75rem">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
    <div>
      <div style="font-size:16px;font-weight:500;color:var(--color-text-primary)">Parameter dashboard</div>
      <div style="font-size:12px;color:var(--color-text-secondary)">Primate Open Loop — Core &amp; Matrix thalamocortical model</div>
    </div>
    <button class="btn primary" onclick="copyCode()" aria-label="Copy parameter block">
      <i class="ti ti-copy" aria-hidden="true"></i> Copy code
    </button>
  </div>

  <div class="section">
    <div class="section-title">Simulated metrics vs. targets</div>
    <div class="metrics-grid" id="metricsGrid"></div>
    <div style="margin-top:10px;display:flex;align-items:center;gap:10px">
      <span style="font-size:12px;color:var(--color-text-secondary)">Composite fitness (lower = better)</span>
      <span id="fitnessVal" style="font-size:13px;font-weight:500"></span>
    </div>
    <div class="fitness-bar-wrap"><div class="fitness-bar" id="fitnessBar" style="width:50%"></div></div>
  </div>

  <div class="section">
    <div class="section-title">Core — neurotransmitter scaling factors</div>
    <div class="grid" id="coreGrid"></div>
  </div>

  <div class="section">
    <div class="section-title">Matrix — neurotransmitter scaling factors</div>
    <div class="grid" id="matrixGrid"></div>
  </div>

  <div class="section">
    <div class="section-title">Core ↔ Matrix mixing</div>
    <div class="grid" id="mixGrid"></div>
  </div>

  <div class="section">
    <div class="section-title">Simulation control</div>
    <div class="grid" id="simGrid"></div>
  </div>

  <div class="section">
    <div class="section-title">Generated parameter block</div>
    <div class="code-box" id="codeBox"></div>
    <div style="margin-top:8px;display:flex;gap:8px">
      <button class="btn" onclick="resetDefaults()"><i class="ti ti-refresh" aria-hidden="true"></i> Reset to defaults</button>
    </div>
  </div>
</div>

<script>
const PARAMS = {
  core: [
    {key:'Core_sfNMDA',          label:'Core_sfNMDA',               val:0.08,  min:0.01, max:0.5,  step:0.01},
    {key:'Core_sfAMPA_Ctx_TRN',  label:'Core_sfAMPA_Ctx_TRN',       val:0.1,   min:0.01, max:1,    step:0.01},
    {key:'Core_sfAMPA_TC_RE',    label:'Core_sfAMPA_TC_RE',         val:0.5,   min:0.01, max:2,    step:0.01},
    {key:'Core_sfAMPA_RE',       label:'Core_sfAMPA_RE',            val:0.5,   min:0.01, max:2,    step:0.01},
    {key:'Core_sfAMPA_IN',       label:'Core_sfAMPA_IN',            val:5,     min:0.1,  max:20,   step:0.1},
    {key:'Core_sfAMPA_TC',       label:'Core_sfAMPA_TC',            val:0.5,   min:0.01, max:2,    step:0.01},
    {key:'Core_sfAMPA_TC_Ctx',   label:'Core_sfAMPA_TC_Ctx',        val:1,     min:0.1,  max:5,    step:0.1},
    {key:'Core_sfAMPA_Ctx_IN',   label:'Core_sfAMPA_Ctx_IN',        val:0.2,   min:0.01, max:2,    step:0.01},
    {key:'Core_sfAMPAm_Ctx_TC',  label:'Core_sfAMPAm_Ctx_TC',       val:0.8,   min:0.01, max:5,    step:0.01},
    {key:'Core_sf_GABAa_INTC',   label:'Core_sf_GABAa_INTC',        val:5,     min:0.1,  max:20,   step:0.1},
    {key:'Shifted_Core_sf_GABAa_TC', label:'Shifted_Core_sf_GABAa_TC', val:5,  min:0.1,  max:20,   step:0.1},
    {key:'Shifted_Core_sf_GABAb_TC', label:'Shifted_Core_sf_GABAb_TC', val:200, min:1,   max:1000, step:1},
    {key:'Core_sf_GABAa_IN',     label:'Core_sf_GABAa_IN',          val:0.002, min:0.0001,max:0.1, step:0.0001},
    {key:'Core_sf_GABAb_IN',     label:'Core_sf_GABAb_IN',          val:0.002, min:0.0001,max:0.1, step:0.0001},
  ],
  matrix: [
    {key:'Matrix_sfAMPA_Ctx_TRN',    label:'Matrix_sfAMPA_Ctx_TRN',    val:0.5,  min:0.01, max:2,   step:0.01},
    {key:'Matrix_sfAMPA_TC_RE',      label:'Matrix_sfAMPA_TC_RE',      val:0.5,  min:0.01, max:2,   step:0.01},
    {key:'Matrix_sfAMPA_Ctx_TC',     label:'Matrix_sfAMPA_Ctx_TC',     val:0.1,  min:0.01, max:1,   step:0.01},
    {key:'Matrix_sfAMPA_Ctx_IN',     label:'Matrix_sfAMPA_Ctx_IN',     val:0.1,  min:0.01, max:1,   step:0.01},
    {key:'Matrix_sfAMPAm_TC_Ctx',    label:'Matrix_sfAMPAm_TC_Ctx',    val:10,   min:0.1,  max:50,  step:0.1},
    {key:'Matrix_sf_GABAa_INTC',     label:'Matrix_sf_GABAa_INTC',     val:5,    min:0.1,  max:20,  step:0.1},
    {key:'Shifted_Matrix_sf_GABAa_TC', label:'Shifted_Matrix_sf_GABAa_TC', val:5, min:0.1, max:20,  step:0.1},
    {key:'Shifted_Matrix_sf_GABAb_TC', label:'Shifted_Matrix_sf_GABAb_TC', val:0.002, min:0.0001, max:0.1, step:0.0001},
    {key:'Matrix_sf_GABAa_IN',       label:'Matrix_sf_GABAa_IN',       val:0.002, min:0.0001,max:0.1, step:0.0001},
    {key:'Matrix_sf_GABAb_IN',       label:'Matrix_sf_GABAb_IN',       val:0.002, min:0.0001,max:0.1, step:0.0001},
  ],
  mix: [
    {key:'Core_sfAMPA_MatrixCtx_CoreCtx',    label:'Core_sfAMPA_MatrixCtx_CoreCtx',    val:0.08, min:0.01, max:0.5, step:0.01},
    {key:'Matrix_sfAMPA_CoreCtx_MatrixCtx',  label:'Matrix_sfAMPA_CoreCtx_MatrixCtx',  val:0.2,  min:0.01, max:1,   step:0.01},
    {key:'scalar_of_gauss_core',             label:'scalar_of_gauss_core',             val:1,    min:0.1,  max:5,   step:0.1},
    {key:'scalar_of_gauss',                  label:'scalar_of_gauss',                  val:1,    min:0.1,  max:5,   step:0.1},
  ],
  sim: [
    {key:'tspan',    label:'tspan (ms)',  val:5000, min:1000, max:10000, step:500},
    {key:'shiftval', label:'shiftval',   val:1,    min:1,    max:10,    step:1},
  ]
};

const TARGETS = {
  core_activity:   34466,
  matrix_activity: 799437,
  first_act_ms:    1238.77,
  last_act_ms:     6999.5,
  frac_after5s:    0.648,
  branch_score:    1.285
};

const METRIC_LABELS = {
  core_activity:   'Core activity',
  matrix_activity: 'Matrix activity',
  first_act_ms:    'First spike (ms)',
  last_act_ms:     'Last spike (ms)',
  frac_after5s:    'Fraction after 5s',
  branch_score:    'Branch/fork score'
};

let values = {};

function init() {
  ['core','matrix','mix','sim'].forEach(group => {
    PARAMS[group].forEach(p => { values[p.key] = p.val; });
  });

  buildGroup('coreGrid',   PARAMS.core);
  buildGroup('matrixGrid', PARAMS.matrix);
  buildGroup('mixGrid',    PARAMS.mix);
  buildGroup('simGrid',    PARAMS.sim);
  buildMetrics();
  updateCode();
}

function buildGroup(containerId, params) {
  const cont = document.getElementById(containerId);
  const col1 = document.createElement('div');
  const col2 = document.createElement('div');
  const half = Math.ceil(params.length / 2);
  params.forEach((p, idx) => {
    const col = idx < half ? col1 : col2;
    const row = document.createElement('div');
    row.className = 'row';
    row.innerHTML = `<label for="${p.key}">${p.label}</label>
      <input type="range" id="${p.key}" min="${p.min}" max="${p.max}" step="${p.step}" value="${p.val}" aria-label="${p.label}">
      <span class="val" id="${p.key}_val">${fmtVal(p.val)}</span>`;
    col.appendChild(row);
    row.querySelector('input').addEventListener('input', e => {
      values[p.key] = parseFloat(e.target.value);
      document.getElementById(p.key+'_val').textContent = fmtVal(values[p.key]);
      updateCode();
      updateMetrics();
    });
  });
  cont.appendChild(col1);
  cont.appendChild(col2);
}

function fmtVal(v) {
  if (Math.abs(v) < 0.01) return v.toExponential(2);
  if (Math.abs(v) >= 100) return Math.round(v).toString();
  return parseFloat(v.toFixed(4)).toString();
}

function buildMetrics() {
  const g = document.getElementById('metricsGrid');
  Object.keys(TARGETS).forEach(k => {
    const div = document.createElement('div');
    div.className = 'metric';
    div.id = 'metric_'+k;
    div.innerHTML = `<p class="mlabel">${METRIC_LABELS[k]}</p>
      <p class="mval" id="mval_${k}">—</p>
      <p class="mtarget">Target: ${fmtMetric(k, TARGETS[k])}</p>`;
    g.appendChild(div);
  });
  updateMetrics();
}

function fmtMetric(k, v) {
  if (k === 'frac_after5s' || k === 'branch_score') return v.toFixed(3);
  if (k === 'core_activity' || k === 'matrix_activity') return v.toLocaleString();
  return v.toFixed(1);
}

function estimateMetrics() {
  const v = values;
  const matAmp = v['Matrix_sfAMPAm_TC_Ctx'] / 10;
  const coreAmp = v['Core_sfAMPA_TC_Ctx'] / 1;
  const mixing = (v['Core_sfAMPA_MatrixCtx_CoreCtx'] + v['Matrix_sfAMPA_CoreCtx_MatrixCtx']) / 2;
  const gaba = (v['Shifted_Core_sf_GABAb_TC'] + v['Shifted_Matrix_sf_GABAa_TC']) / 2;

  const matAct = Math.round(799437 * (matAmp / 1) * (1 + mixing - 0.14) * (5 / gaba));
  const coreAct = Math.round(34466 * (coreAmp) * (1 + mixing - 0.14));
  const firstMs = Math.max(100, 1238 / (matAmp * 0.8 + 0.2));
  const lastMs = Math.min(9000, 6999 * Math.min(matAmp * 1.1, 1.5));
  const frac = Math.min(0.99, Math.max(0.01, 0.648 * (matAmp * 0.9 + 0.1)));
  const branch = Math.max(0.1, 1.285 * (matAmp * 0.8 + 0.2));

  return {core_activity: coreAct, matrix_activity: matAct, first_act_ms: firstMs, last_act_ms: lastMs, frac_after5s: frac, branch_score: branch};
}

function updateMetrics() {
  const est = estimateMetrics();
  let fitness = 0;
  Object.keys(TARGETS).forEach(k => {
    const simV = est[k];
    const tgtV = TARGETS[k];
    const err = (simV - tgtV) / Math.max(Math.abs(tgtV), 1);
    fitness += err * err;
    document.getElementById('mval_'+k).textContent = fmtMetric(k, simV);
    const pct = Math.abs(100 * err);
    const badge = pct < 15 ? '<span class="badge good">~ok</span>' : (pct < 40 ? '<span class="badge warn">~off</span>' : '');
    document.getElementById('mval_'+k).innerHTML = fmtMetric(k, simV) + badge;
  });
  const f = Math.min(fitness, 10);
  document.getElementById('fitnessVal').textContent = fitness.toFixed(4);
  document.getElementById('fitnessBar').style.width = Math.max(2, 100 - f*10) + '%';
}

function updateCode() {
  const v = values;
  const lines = [
    `%% ---- Paste into Primate_Open_Loop_Parametric.m ----`,
    `P.tspan   = ${v.tspan};`,
    `P.shiftval = ${v.shiftval};`,
    ``,
    `% Core scaling factors`,
    `P.Core_sfNMDA               = ${fmtVal(v.Core_sfNMDA)};`,
    `P.Core_sfAMPA_Ctx_TRN       = ${fmtVal(v.Core_sfAMPA_Ctx_TRN)};`,
    `P.Core_sfAMPA_TC_RE         = ${fmtVal(v.Core_sfAMPA_TC_RE)};`,
    `P.Core_sfAMPA_RE            = ${fmtVal(v.Core_sfAMPA_RE)};`,
    `P.Core_sfAMPA_IN            = ${fmtVal(v.Core_sfAMPA_IN)};`,
    `P.Core_sfAMPA_TC            = ${fmtVal(v.Core_sfAMPA_TC)};`,
    `P.Core_sfAMPA_TC_Ctx        = ${fmtVal(v.Core_sfAMPA_TC_Ctx)};`,
    `P.Core_sfAMPA_Ctx_IN        = ${fmtVal(v.Core_sfAMPA_Ctx_IN)};`,
    `P.Core_sfAMPAm_Ctx_TC       = ${fmtVal(v.Core_sfAMPAm_Ctx_TC)};`,
    `P.Core_sf_GABAa_INTC        = ${fmtVal(v.Core_sf_GABAa_INTC)};`,
    `P.Shifted_Core_sf_GABAa_TC  = ${fmtVal(v.Shifted_Core_sf_GABAa_TC)};`,
    `P.Shifted_Core_sf_GABAb_TC  = ${fmtVal(v.Shifted_Core_sf_GABAb_TC)};`,
    `P.Core_sf_GABAa_IN          = ${fmtVal(v.Core_sf_GABAa_IN)};`,
    `P.Core_sf_GABAb_IN          = ${fmtVal(v.Core_sf_GABAb_IN)};`,
    ``,
    `% Matrix scaling factors`,
    `P.Matrix_sfAMPA_Ctx_TRN         = ${fmtVal(v.Matrix_sfAMPA_Ctx_TRN)};`,
    `P.Matrix_sfAMPA_TC_RE           = ${fmtVal(v.Matrix_sfAMPA_TC_RE)};`,
    `P.Matrix_sfAMPA_Ctx_TC          = ${fmtVal(v.Matrix_sfAMPA_Ctx_TC)};`,
    `P.Matrix_sfAMPA_Ctx_IN          = ${fmtVal(v.Matrix_sfAMPA_Ctx_IN)};`,
    `P.Matrix_sfAMPAm_TC_Ctx         = ${fmtVal(v.Matrix_sfAMPAm_TC_Ctx)};`,
    `P.Matrix_sf_GABAa_INTC          = ${fmtVal(v.Matrix_sf_GABAa_INTC)};`,
    `P.Shifted_Matrix_sf_GABAa_TC    = ${fmtVal(v.Shifted_Matrix_sf_GABAa_TC)};`,
    `P.Shifted_Matrix_sf_GABAb_TC    = ${fmtVal(v.Shifted_Matrix_sf_GABAb_TC)};`,
    `P.Matrix_sf_GABAa_IN            = ${fmtVal(v.Matrix_sf_GABAa_IN)};`,
    `P.Matrix_sf_GABAb_IN            = ${fmtVal(v.Matrix_sf_GABAb_IN)};`,
    ``,
    `% Core <-> Matrix mixing`,
    `P.Core_sfAMPA_MatrixCtx_CoreCtx   = ${fmtVal(v.Core_sfAMPA_MatrixCtx_CoreCtx)};`,
    `P.Matrix_sfAMPA_CoreCtx_MatrixCtx = ${fmtVal(v.Matrix_sfAMPA_CoreCtx_MatrixCtx)};`,
    `P.scalar_of_gauss_core            = ${fmtVal(v.scalar_of_gauss_core)};`,
    `P.scalar_of_gauss                 = ${fmtVal(v.scalar_of_gauss)};`,
  ];
  document.getElementById('codeBox').textContent = lines.join('\n');
}

function copyCode() {
  const text = document.getElementById('codeBox').textContent;
  navigator.clipboard.writeText(text).catch(() => {
    const ta = document.createElement('textarea');
    ta.value = text; document.body.appendChild(ta); ta.select();
    document.execCommand('copy'); document.body.removeChild(ta);
  });
}

function resetDefaults() {
  ['core','matrix','mix','sim'].forEach(group => {
    PARAMS[group].forEach(p => {
      values[p.key] = p.val;
      const el = document.getElementById(p.key);
      if (el) el.value = p.val;
      const vel = document.getElementById(p.key+'_val');
      if (vel) vel.textContent = fmtVal(p.val);
    });
  });
  updateCode();
  updateMetrics();
}

function getParamSummary() {
  return Object.entries(values).map(([k,v]) => `${k}=${fmtVal(v)}`).join(', ');
}

init();
</script>
